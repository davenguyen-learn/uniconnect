# ── Database ──
POSTGRES_USER=uniconnect
POSTGRES_PASSWORD=uniconnect_dev_pwd
POSTGRES_DB=uniconnect
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://uniconnect:uniconnect_dev_pwd@db:5432/uniconnect

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── App ──
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Storage (Cloudflare R2) ──
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=uniconnect
R2_PUBLIC_URL=

# ── AI Services ──
GEMINI_API_KEY=

